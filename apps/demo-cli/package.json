{
  "name": "@hman/demo-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Demo CLI for testing HMAN functionality",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "hman-demo": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
