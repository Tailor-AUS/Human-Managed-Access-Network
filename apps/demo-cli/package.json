    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hman/core": "workspace:*",
    "@hman/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
