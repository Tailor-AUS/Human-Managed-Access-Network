# .HMAN web dashboard — production environment
#
# Copy this to .env.production and fill in your real bridge URL.
# Build with `npm run build`; deploy with `npm run deploy` (see wrangler.toml).
#
# The bridge URL is whatever Cloudflare Tunnel (or other reverse proxy)
# gives you. For a named tunnel on example.com it will be e.g.
# https://bridge.example.com.

VITE_HMAN_BRIDGE=https://bridge.example.com
